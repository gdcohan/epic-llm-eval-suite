# --- Epic FHIR (SMART Backend Services) ---
EPIC_CLIENT_ID=""
EPIC_PRIVATE_KEY_PATH="privatekey.pem"
EPIC_FHIR_BASE_URL="https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4"
EPIC_TOKEN_URL="https://fhir.epic.com/interconnect-fhir-oauth/oauth2/token"
# Optional: comma-separated DocumentReference identifier systems to try when an
# input note ID is an Epic-native value (e.g. a document/note ID) with no system.
# Fill from your Epic environment; leave blank to rely on direct/bare-value lookup.
EPIC_DOC_IDENTIFIER_SYSTEMS=""

# --- LLM-as-jury ---
# JURY_MODE: "stub" (offline, deterministic; default) or "live".
JURY_MODE="stub"
# Single-provider fallback panel (three personas of one model). Same-model
# personas tend to agree -- prefer JURY_PANEL below for real disagreement.
JURY_PROVIDER="anthropic"
JURY_MODEL="claude-sonnet-4-6"
# TRUE cross-vendor jury: one member per comma-separated 'provider:model[:temp]'.
# Takes precedence over JURY_PROVIDER/JURY_MODEL when set (and JURY_MODE=live).
# JURY_PANEL="anthropic:claude-sonnet-4-6,openai:gpt-4o"

OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
